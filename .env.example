# Vercel Environment Variables for Firebase
# Copy these keys into your Vercel Project Settings -> Environment Variables
# These variables will override the default firebase-applet-config.json

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_id
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
